# Caddy reverse proxy.
#
# One job: take all incoming HTTPS traffic on $DOMAIN and forward it to the
# FastAPI server. Caddy automatically obtains and renews a Let's Encrypt
# certificate (needs ports 80 + 443 reachable from the internet, which the
# ACME challenge uses).
#
# WebSockets work out of the box — Caddy 2 transparently upgrades the
# connection when it sees Upgrade: websocket. /api, /uploads, /app and /ws
# all live behind one upstream, so a single reverse_proxy line is enough.

{
	# Email used to register the ACME account with Let's Encrypt. Set in
	# the host .env as ACME_EMAIL=you@yourdomain so cert-expiry warnings
	# can reach you. If unset, Let's Encrypt registers without an email
	# (you just don't get notified before a cert expires).
	email {$ACME_EMAIL}
}

# Public hostname comes from the host .env (DOMAIN=foo.duckdns.org).
{$DOMAIN} {
	# gzip / zstd for static assets — the React bundle is ~2 MB, this
	# typically halves the transfer.
	encode zstd gzip

	# Long-running WebSocket connections need no idle timeout — Caddy's
	# default reverse_proxy is fine for these, but we bump the flush so
	# audio/voice metadata frames don't sit in a buffer.
	reverse_proxy server:8000 {
		flush_interval -1
	}
}
