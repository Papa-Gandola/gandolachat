{
  "expo": {
    "name": "GandolaChat",
    "slug": "gandolachat",
    "version": "0.6.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gandolachat",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "android": {
      "package": "com.gandola.chat",
      "versionCode": 6,
      "usesCleartextTraffic": true,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png",
      "name": "GandolaChat",
      "shortName": "Gandola",
      "themeColor": "#0a0a0a",
      "backgroundColor": "#0a0a0a",
      "description": "GandolaChat — мессенджер для своих.",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "ru",
      "startUrl": "/app/",
      "scope": "/app/"
    },
    "experiments": {
      "baseUrl": "/app"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GandolaChat использует камеру и галерею для отправки фото в чат."
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "GandolaChat использует камеру для видеозвонков.",
          "microphonePermission": "GandolaChat использует микрофон для звонков."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "GandolaChat использует микрофон для записи голосовых сообщений."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "GandolaChat использует камеру для съёмки фото в чат."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "GandolaChat сохраняет полученные фото в галерею.",
          "savePhotosPermission": "GandolaChat сохраняет полученные фото в галерею.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#c6ff3d",
          "defaultChannel": "default",
          "androidMode": "default",
          "androidCollapsedTitle": "GandolaChat"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://2-26-117-77.sslip.io",
      "wsUrl": "wss://2-26-117-77.sslip.io",
      "eas": {
        "projectId": "40d53c62-406d-44e9-99ae-bb4c01a3dc28"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/40d53c62-406d-44e9-99ae-bb4c01a3dc28",
      "fallbackToCacheTimeout": 3000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
