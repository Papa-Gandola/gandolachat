{
  "expo": {
    "name": "GandolaChat",
    "slug": "gandolachat",
    "version": "0.4.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gandolachat",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "android": {
      "package": "com.gandola.chat",
      "versionCode": 4,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GandolaChat использует камеру и галерею для отправки фото в чат."
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "GandolaChat использует камеру для видеозвонков.",
          "microphonePermission": "GandolaChat использует микрофон для звонков."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "GandolaChat использует микрофон для записи голосовых сообщений."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "GandolaChat использует камеру для съёмки фото в чат."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "GandolaChat сохраняет полученные фото в галерею.",
          "savePhotosPermission": "GandolaChat сохраняет полученные фото в галерею.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "apiUrl": "http://2.26.117.77:8000",
      "wsUrl": "ws://2.26.117.77:8000",
      "eas": {
        "projectId": "40d53c62-406d-44e9-99ae-bb4c01a3dc28"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/40d53c62-406d-44e9-99ae-bb4c01a3dc28",
      "fallbackToCacheTimeout": 3000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
