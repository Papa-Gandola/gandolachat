{
  "expo": {
    "name": "GandolaChat",
    "slug": "gandolachat",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gandolachat",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "android": {
      "package": "com.gandola.chat",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "GandolaChat использует камеру и галерею для отправки фото в чат."
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "GandolaChat использует камеру для видеозвонков.",
          "microphonePermission": "GandolaChat использует микрофон для звонков."
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://2.26.117.77:8000",
      "wsUrl": "ws://2.26.117.77:8000",
      "eas": {
        "projectId": "40d53c62-406d-44e9-99ae-bb4c01a3dc28"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/40d53c62-406d-44e9-99ae-bb4c01a3dc28",
      "fallbackToCacheTimeout": 3000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
