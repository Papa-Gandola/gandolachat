{
  "name": "gandola-chat",
  "version": "1.1.0",
  "description": "GandolaChat — a simple Discord-like desktop messenger",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && tsc -p tsconfig.main.json",
    "dist": "npm run build && electron-builder",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-peer": "^9.11.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/simple-peer": "^9.11.8",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-node-polyfills": "^0.26.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.gandola.chat",
    "productName": "GandolaChat",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "Papa-Gandola",
      "repo": "gandolachat"
    },
    "artifactName": "GandolaChat-Setup-${version}.${ext}",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GandolaChat"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ]
  }
}
