# Copy to .env on the VPS (next to docker-compose.yml) and fill in your values.
# Compose reads this file automatically; do NOT commit your real .env.

# Public hostname Caddy will issue a Let's Encrypt cert for. Must be a real
# DNS name pointing to this server's IPv4 (and ideally IPv6) — Let's Encrypt
# refuses bare IP addresses. DuckDNS (free) or any other provider works.
DOMAIN=yourname.duckdns.org

# Email for the ACME account. Optional but recommended — Let's Encrypt uses
# it to warn ~20 days before a cert is about to expire if auto-renewal stops
# working. Leave empty to skip registration with an address.
ACME_EMAIL=you@example.com

# Random string used to sign JWTs. Generate once with `openssl rand -hex 32`
# and keep it stable — changing it invalidates every existing login token.
SECRET_KEY=change-me-with-openssl-rand-hex-32
